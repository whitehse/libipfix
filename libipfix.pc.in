prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: libipfix
Description: Pure C IPFIX receiver (RFC 7011) — syscall-free, callback-free
Version: @PROJECT_VERSION@
Libs: -L${libdir} -lipfix
Cflags: -I${includedir}
